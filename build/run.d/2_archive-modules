# read build environment
source build/conf.d/0_general

cd "$KERNELDIR"

# create modules archive
rm -f "$MODULESARCHIVE"
tar -c -I 'xz -T0' -f "$MODULESARCHIVE" "lib" || exit 1

# copy modules archive to package
cp "$MODULESARCHIVE" "$PKGVARDIR" || exit 1

cd "$BUILDROOT"
