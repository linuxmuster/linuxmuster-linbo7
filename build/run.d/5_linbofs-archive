# read build environment
source build/config/build.env || exit 1

echo
echo "##############################"
echo "# Creating linbofs64 archive #"
echo "##############################"

# provide linbo version in linbo directory on server
mkdir -p "$LINBODIR"
cp "$LINBOFSDST/etc/linbo-version" "$LINBODIR"

# create linbofs archive
cd "$CACHE"
mkdir -p "$PKGVARDIR"
sudo chown root:root "$LINBOFSDST" -R
sudo tar -v -c -I 'xz -T0' -f "$LINBOFSARCHIVE" "linbofs64" || exit 1
cd "$BUILDROOT"
