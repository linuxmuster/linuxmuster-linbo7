# build.conf
# general environment variables
# thomas@linuxmuster.net
# 20260512
#

# must be buildroot
BUILDROOT="$(pwd)"

# build user and group
MYNAME="$(id -n -u)"
MYGROUP="$(id -n -g)"

# dirs relative to buildroot
BUILDDIR="$BUILDROOT/build"
BUILDBIN="$BUILDDIR/bin"
BUILDCONFD="$BUILDDIR/conf.d"
BUILDCONFIG="$BUILDDIR/config"
BUILDINITD="$BUILDDIR/initramfs.d"
BUILDPATCHES="$BUILDDIR/patches"
BUILDRUND="$BUILDDIR/run.d"
CACHE="$BUILDROOT/cache"
DEBIAN="$BUILDROOT/debian"
SRC="$BUILDROOT/src"
SERVERFS="$SRC/serverfs"
TMPDIR="$BUILDROOT/tmp"
KMODTMP="$TMPDIR/modules"

# package data
PKGNAME="linuxmuster-linbo7"
PKGBUILDROOT="$DEBIAN/$PKGNAME"
PKGVARDIR="$PKGBUILDROOT/var/lib/linuxmuster/linbo"

# linbofs
LINBOFSSRC="$SRC/linbofs"
LINBOFSDST="$CACHE/linbofs64"
LINBOFSAPPS="$BUILDCONFIG/linbofs.apps"
LINBOFSROOT="boot cache dev etc home image media mnt opt proc root run srv \
  sys tmp usr/bin usr/sbin usr/lib usr/lib32 usr/lib64 usr/libx32 var"
LINBOFSPERMS="root 700
  tmp 777"
LINBOFSLINKS="usr/bin bin
  usr/lib lib
  usr/lib32 lib32
  usr/lib64 lib64
  usr/libx32 libx32
  usr/sbin sbin
  /run var/run"
LINBOFSNODES="dev/console 644 c 5 1
  dev/null 666 c 1 3"
LINBOFSARCHIVE="$PKGVARDIR/linbofs64.tar.xz"
LINBOSPLASH="$SRC/linbo-splash"
LINBORELEASE="$(head -1 "$DEBIAN/releasename")"
LINBOVERSION="$(head -n 1 "$DEBIAN/changelog" | awk -F\( '{print $2}' | awk -F\) '{print $1}')"

# linbo server side dir
LINBODIR="$PKGBUILDROOT/srv/linbo"

# kernel
KERNELVER="$(ls /lib/modules/ | tail -1)"
SRCMODDIR="/lib/modules/$KERNELVER"
DSTMODDIR="$CACHE/lib/modules/$KERNELVER"
INITRDFSRC="/boot/initrd.img-$KERNELVER"
MODLISTDIR="$BUILDCONFIG/modules.d"
MODARCHIVE="$PKGVARDIR/modules.tar.xz"

# busybox applets to remove because we use the corresponding ubuntu binaries (see linbofs.apps)
BBREMOVE="blkid fdisk find mdev mke2fs tar"

# grub.cfg.local will be copied to linbofs
GRUBCFGSRC="$SERVERFS/usr/share/linuxmuster/linbo/templates/grub.cfg.local"
GRUBCFGDST="$LINBOFSDST/usr/share/grub/grub.cfg"
